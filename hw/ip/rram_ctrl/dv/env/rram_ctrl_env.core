name: "lowrisc:dv:rram_ctrl_env:0.1"
description: "RRAM_CTRL DV UVM environment"
filesets:
  files_dv:
    depend:
      - lowrisc:dv:ralgen
      - lowrisc:dv:cip_lib
      - lowrisc:dv:tl_agent
      - lowrisc:dv:dv_base_reg
      - lowrisc:dv:rram_macro_env
    files:
      - rram_ctrl_host_ral_pkg.sv
      - rram_ctrl_env_pkg.sv
      - rram_ctrl_env_cfg.sv: {is_include_file: true}
      - rram_ctrl_env_cov.sv: {is_include_file: true}
      - rram_ctrl_virtual_sequencer.sv: {is_include_file: true}
      - rram_ctrl_scoreboard.sv: {is_include_file: true}
      - rram_ctrl_env.sv: {is_include_file: true}
      - seq_lib/rram_ctrl_vseq_list.sv: {is_include_file: true}
      - seq_lib/rram_ctrl_base_vseq.sv: {is_include_file: true}
      - seq_lib/rram_ctrl_common_vseq.sv: {is_include_file: true}
      - seq_lib/rram_ctrl_smoke_vseq.sv: {is_include_file: true}
    file_type: systemVerilogSource

generate:
  ral:
    generator: ralgen
    parameters:
      name: rram_ctrl
      ip_hjson: ../../data/rram_ctrl.hjson
    position: prepend

targets:
  default:
    filesets:
      - files_dv
    generate:
      - ral

// SPDX-License-Identifier: Apache-2.0
{
  name:               "i3c",
  human_name:         "I3C",
  one_line_desc:      "I3C Controller/Target",
  one_paragraph_desc: '''I3C block'''
  // Unique comportable IP identifier defined under KNOWN_CIP_IDS in the regtool.
  cip_id:             "45",
  design_spec:        "../doc",
  dv_doc:             "../doc/dv",
  hw_checklist:       "../doc/checklist",
  sw_checklist:       "/sw/device/lib/dif/dif_i3c",
  revisions: [
  {
    version:            "1.0.0",
    life_stage:         "L2",
    design_stage:       "D3",
    verification_stage: "V3",
    commit_id:          "",
    notes:              ""
  }
  ]
  clocking: [
    {clock: "clk_i", reset: "rst_ni", primary: true}
    {clock: "clk_aon_i", reset: "rst_aon_ni"},
    // The scan_rst_ni port isn't listed here because it's generated by the
    // "scan_reset: true" below.
    {clock: "scan_clk_i"}
  ],
  bus_interfaces: [
    { protocol: "tlul", direction: "device", racl_support: true }
  ],
  available_inout_list: [
    { name: "ctrl_scl", desc: "I3C Controller clock" }
    { name: "ctrl_sda", desc: "I3C Controller data" }
    { name: "targ_sda", desc: "I3C Target data" }
  ],
  available_input_list: [
    { name: "targ_scl", desc: "I3C Target clock input" }
  ],
  available_output_list: [
    { name: "ctrl_scl_pp_en", desc: "I3C Controller clock Push-pull enable output" }
    { name: "ctrl_sda_pp_en", desc: "I3C Controller data Push-pull enable output" }
    { name: "ctrl_sda_od_en", desc: "I3C Controller data Open Drain enable output" }
    { name: "ctrl_scl_pu_en", desc: "I3C Controller clock Pullup enable output" }
    { name: "ctrl_sda_pu_en", desc: "I3C Controller clock Pullup enable output" }
    { name: "scl_hk_en", desc: "I3C Controller clock High-keeper enable output" }
    { name: "sda_hk_en", desc: "I3C Controller clock High-keeper enable output" }

    { name: "targ_sda_pp_en", desc: "I3C Target data Push-pull enable output" }
    { name: "targ_sda_od_en", desc: "I3C Target data Open Drain enable output" }
  ],
  interrupt_list: [
    // Global HCI interrupt, asserted when any HCI interrupt is pending.
    { name:    "hci",
      type:    "status",
      default: "0",
      desc:    "HCI interrupt."
    }
    // Global Target interrupt, asserted when any Target interrupt is pending.
    { name:    "targ",
      type:    "status",
      default: "0",
      desc:    "Target interrupt."
    }
  ],
  alert_list: [
    { name: "fatal_fault",
      desc: "This fatal alert is triggered when a fatal TL-UL bus integrity fault is detected."
    }
  ],
  inter_signal_list: [
    { struct:  "logic",
      package: "",
      type:    "uni",
      name:    "rstdet_enable",
      act:     "req"
    }
    { struct:  "i3c_rstdet_req"
      package: "i3c_pkg"
      type:    "uni"
      name:    "rstdet_req"
      act:     "req"
    }
    { struct:  "i3c_rstdet_rsp"
      package: "i3c_pkg"
      type:    "uni"
      name:    "rstdet_rsp"
      act:     "rcv"
    }
    { struct:  "logic"
      package: ""
      type:    "uni"
      name:    "mbist_en"
      act:     "rcv"
    }
    // RAM configuration
    { struct:  "ram_1p_cfg"
      package: "prim_ram_1p_pkg"
      type:    "uni"
      name:    "ram_cfg"
      act:     "rcv"
    }
    { struct:  "ram_1p_cfg_rsp"
      package: "prim_ram_1p_pkg"
      type:    "uni"
      name:    "ram_cfg_rsp"
      act:     "req"
    }
    { struct:  "ram_1p_cfg"
      package: "prim_ram_1p_pkg"
      type:    "uni"
      name:    "dat_cfg"
      act:     "rcv"
    }
    { struct:  "ram_1p_cfg_rsp"
      package: "prim_ram_1p_pkg"
      type:    "uni"
      name:    "dat_cfg_rsp"
      act:     "req"
    }
    { struct:  "ram_1p_cfg"
      package: "prim_ram_1p_pkg"
      type:    "uni"
      name:    "dct_cfg"
      act:     "rcv"
    }
    { struct:  "ram_1p_cfg_rsp"
      package: "prim_ram_1p_pkg"
      type:    "uni"
      name:    "dct_cfg_rsp"
      act:     "req"
    }
    { struct:  "racl_policy_vec",
      type:    "uni",
      name:    "racl_policies",
      act:     "rcv",
      package: "top_racl_pkg",
      desc:    '''Incoming RACL policy vector from a racl_ctrl instance.
               The policy selection vector (parameter) selects the policy for each register.
               '''
    }
    { struct:  "racl_error_log",
      type:    "uni",
      name:    "racl_error",
      act:     "req",
      width:   "1"
      package: "top_racl_pkg",
      desc:    "RACL error log information of this module."
    }
  ]
  scan: "true",       // Enable `scanmode_i` port
  scan_reset: "true", // Enable `scan_rst_ni` port
  param_list: [
    // TODO: Resolve this duplication of word counts and entry counts.
    // Device Address Table size in bus words; each entry consumes 8 bytes of address space.
    { name:    "NumDATWords",
      type:    "int unsigned",
      default: "64",
      desc:    "Size of the Device Address Table in bus words."
    },
    // Device Characteristics Table size in bus words; each entry consumes 16 bytes of address space.
    { name:    "NumDCTWords",
      type:    "int unsigned",
      default: "128",
      desc:    "Size of the Device Characteristics Table in bus words."
    }
    { name:    "NumDXTWords",
      type:    "int unsigned",
      default: "256",
      desc:    "Size of the Device Address Table and Device Characteristics Table in bus words."
    }
    { name:    "MaxTargets",
      type:    "int unsigned",
      default: "4",
      desc:    "The maximumm number of Virtual Targets supported."
    }
    { name:    "MaxGroups",
      type:    "int unsigned",
      default: "8",
      desc:    "The maximum number of Group Addresses supported on the Target side."
    }
  ]
  regwidth: "32",
  registers: [
    { name:     "INFO",
      desc:     "IP block information.",
      swaccess: "ro",
      hwaccess: "hwo",
      hwext:    "true",
      fields: [
        { bits:   "28:18"
          name:   "BUF_DWORD_MAX",
          desc:   '''Index of the final DWORD of the shared Message Buffer.
                  i.e. one less than its size in DWORDs.
                  ''',
          resval: "0x3ff"
        }
        { bits:   "17:13",
          name:   "DCT_ENTRY_MAX",
          desc:   '''Index of the final entry of the Device Characteristics Table.
                  i.e. one less than the number of entries.
                  ''',
          resval: "31"
        }
        { bits:   "12:8",
          name:   "DAT_ENTRY_MAX",
          desc:   '''Index of the final entry of the Device Address Table.
                  i.e. one less than the number of entries.
                  ''',
          resval: "31"
        }
        { bits:   "7:4",
          name:   "VERSION",
          desc:   "Version number of the IP block.",
          resval: "1"
        }
        { bits:   "3:0",
          name:   "REVISION",
          desc:   "Revision number of the IP block.",
          resval: "0"
        }
      ]
    }
    { name:     "CTRL_CONTROL",
      desc:     "Controller-side Control register.",
      swaccess: "rw",
      hwaccess: "hro",
      fields: [
        { bits:   "0",
          name:   "DUMMY",
          desc:   "Dummy field; no IP control signals yet.",
          resval: "0"
        }
      ]
    }
    { name:     "CTRL_STATUS",
      desc:     "Controller-side Status register.",
      swaccess: "ro",
      hwaccess: "hwo",
      hwext:    "true",
      fields: [
        { bits:   "31",
          name:   "PRESENT",
          desc:   "Indicates the presence of Controller-side logic.",
          resval: "0"
        }
      ]
    }
    { name: "CTRL_ERROR",
      desc: "Controller Error counts."
      swaccess: "rw1c",
      hwaccess: "hrw",
      fields: [
        { bits:   "15:12",
          name:   "CE3",
          desc:   "Count of type 3 Controller Errors.",
          resval: "0"
        }
        { bits:   "11:8",
          name:   "CE2",
          desc:   "Count of type 2 Controller Errors.",
          resval: "0"
        }
        { bits:   "7:4",
          name:   "CE1",
          desc:   "Count of type 1 Controller Errors.",
          resval: "0"
        }
        { bits:   "3:0",
          name:   "CE0",
          desc:   "Count of type 0 Controller Errors.",
          resval: "0"
        }
      ]
    }
    { name: "TARG_CONTROL",
      desc: "Target Control register.",
      fields: [
        // TODO: Shall we need to reset individual Virtual Targets in any sense?
        { bits:     "31",
          name:     "RESET",
          desc:     '''Software reset of Target logic.

                    Iff the Standby Controller support is disabled by clearing `STBY_CR_SUPPORT`, writing '1' to this field will reset all of the Target-side logic.
                    To reset the Target-side logic when Standby Controller support is enabled, software shall instead use the `SOFT_RST` field of the HCI-specified `RESET_CONTROL` register, whether or not the Controller is currently the Active Controller.
                    ''',
          hwqe:     "true",
          swaccess: "wo",
          hwaccess: "hro",
          resval:   "0"
        }
        { bits:     "30",
          name:     "HJ_REQUEST",
          desc:     '''Issue Hot-Join request.

                    This applies to all Virtual Target since they share a single physical Target.
                    Software shall set this to '1' to issue the request, and the hardware will clear
                    it when the request has been sent and acknowledged.
                    ''',
          hwqe:     "true",
          swaccess: "rw",
          hwaccess: "hrw",
          resval:   "0"
        }
        { bits:     "4",
          name:     "CRHDLY1_SET_AS",
          desc:     "Set Bus Activity State.",
          swaccess: "rw",
          hwaccess: "hro",
          resval:   "0"
        }
        { bits:     "3:2",
          name:     "CRHDLY1_AS",
          desc:     "Controller Handoff Activity State.",
          swaccess: "rw",
          hwaccess: "hro",
          resval:   "0"
        }
        { bits:     "1",
          name:     "STBY_CR_SUPPORT",
          desc:     '''Standby Controller role supported.

                    When set the Controller shall have the option of performing Controller Role handoff and switching into Standby Controller mode.
                    If this field is clear the Controller will refuse to handoff the bus when requested and will instead remain the Active Controller,
                    thus freeing up the first Virtual Target to operate independently as a dedicated Target device.
                    '''
          swaccess: "rw",
          hwaccess: "hro",
          resval:   "1"
        }
        { bits:     "0",
          name:     "EN",
          desc:     '''Target enable.

                    Enable the Target-side logic as a separate I3C device, instead of supporting Standby Controller mode.
                    In this configuration the Controller-side logic must remain the Active Controller and cannot perform Controller Role handoff.
                    ''',
          swaccess: "rw",
          hwaccess: "hro",
          resval:   "0"
        }
      ]
    }
    { name:     "TARG_STATUS",
      desc:     "Target-side Status register",
      swaccess: "ro",
      hwext:    "true",
      fields: [
        { bits:     "31",
          name:     "PRESENT",
          desc:     "Indicates the presence of Target-side logic.",
          hwaccess: "hwo",
          resval:   "1"
        }
        { bits:     "26",
          name:     "PROTOCOL_ERROR",
          desc:     "Protocol error detected since the last GETSTATUS CCC to read this indicator.",
          hwaccess: "hrw",
          resval:   "0"
        }
        { bits:     "25",
          name:     "VTM",
          desc:     "Vendor Test Mode active, in response to ENTTM.",
          hwaccess: "hwo",
          resval:   "0"
        }
        { bits:     "24",
          name:     "RSTACT_VIRT_TARG_DET",
          desc:     "RSTACT Virtual Target Detect.",
          hwaccess: "hwo",
          resval:   "0"
        }
        { bits:     "23:16",
          name:     "RSTACT",
          desc:     "Configured Target Reset action.",
          hwaccess: "hwo",
          resval:   "0"
        }
      ]
    }
    { name:     "TARG_SINK_CONTROL",
      desc:     "Target data sink control.",
      swaccess: "rw",
      fields: [
        { bits:     "31",
          name:     "START",
          desc:     '''Initiate removal of DWORDs from a transmission buffer.

                    The 'data sink' logic is a mechanism for recovering from aborting or failed transmissions without impacting subsequent, already-queued transfers.
                    Software shall write '1' to this field to start the 'data sink' logic.
                    The ACTIVE field in the corresponding `TARG_SINK_STATUS` register shows whether the logic is still active.
                    '''
          hwqe:     "true",
          hwaccess: "hrw",
          resval:   "0"
        }
        { bits:     "27:16",
          name:     "LENGTH",
          desc:     '''Specifies the number of DWORDs to be removed, minus 1.

                    This field instructs the 'data sink' logic to remove a specified number of DWORDs of data from the specified source.
                    Software shall program 'n-1' into this field to remove 'n' DWORDs.
                    '''
          hwaccess: "hrw",
          resval:   "0"
        }
        { bits:     "14:12",
          name:     "SRC",
          desc:     '''Specifies the transmission buffer from which DWORDs are to be removed.

                    0 - IBI Data buffer.
                    1 - Virtual Target 0
                    2 - Virtual Target 1...
                    ''',
          hwaccess: "hro",
          resval:   "0"
        }
      ]
    }
    { name:     "TARG_SINK_STATUS",
      desc:     "Target data sink status.",
      swaccess: "ro",
      hwaccess: "hwo",
      hwext:    "true",
      fields: [
        { bits:   "1",
          name:   "ERROR",
          desc:   '''Indicates whether the data sink mechanism stopped prematurely.
                  If the specified source buffer did not contain sufficient data for the logic to remove the specified number of DWORDs it will set this bit when becoming inactive.
                  '''
          resval: "0"
        }
        { bits:   "0",
          name:   "ACTIVE",
          desc:   '''Indicates whether the data sink logic is active.
                  This bit becomes set when the operation is started and will be cleared at most a few tens of microseconds later when the operation is complete.
                  '''
          resval: "0"
        }
      ]
    }
    // TODO: The reset detector requires an asynchronous clock signal for its register interface;
    // even though the reset detector logic itself operates on the SCL signal this cannot be used
    // for the register interface because doing so could stall the CPU indefinitely.
    // We're using `clk_aon_i` for this purpose.
    { name:     "RESET_DET_CTRL",
      desc:     "Reset detector control.",
      swaccess: "wo",
      hwaccess: "hro",
      hwext:    "true",
      hwqe:     "true",
      async:    "clk_aon_i",
      fields: [
        { bits:   "21",
          name:   "RST_TARGET_EN",
          desc:   "Enable response to a Whole Target request request.",
          resval: "0"
        }
        { bits:   "20",
          name:   "RST_PERIPH_EN",
          desc:   "Enable response to a Peripheral reset request.",
          resval: "0"
        }
        { bits:   "16",
          name:   "WAKE_ACK",
          desc:   "Wake acknowledgement.",
          resval: "0"
        }
        { bits:   "1",
          name:   "SLEEP_REQ",
          desc:   "Activate the reset detector prior to entry into 'Deepest Sleep' state.",
          resval: "0",
          tags: [// Prevent usb wake functions from being turned on outside of directed tests
                 "excl:CsrNonInitTests:CsrExclWrite"]
        }
      ]
    }
    { name:     "RESET_DET_STATUS",
      desc:     "Reset detector status.",
      swaccess: "ro",
      hwaccess: "hwo",
      async:    "clk_aon_i",
      fields: [
        { bits:   "3",
          name:   "RST_TARGET",
          desc:   "Indicates that a Whole Target reset requst was received.",
          resval: "0"
        }
        { bits:   "2",
          name:   "RST_PERIPH",
          desc:   "Indicates that a Peripheral request request was received.",
          resval: "0"
        }
        { bits:   "1",
          name:   "WAKE_UP",
          desc:   "Indicates that a Wake Up request was received.",
          resval: "0"
        },
        { bits:   "0",
          name:   "ACTIVE",
          desc:   "Indicates whether the reset detector is active.",
          resval: "0"
        }
      ]
    }
    { name:     "CTRL_TIME0",
      desc:     "Controller Timing Parameters 0",
      swaccess: "rw",
      hwaccess: "hro"
      fields: [
        { bits:   "25:16",
          name:   "TCAS_DIV2",
          desc:   '''Half of the delay between SDA falling and SCL falling in START timing, minus 1.
                  This interval is in terms of the IP clock period.
                  '''
          resval: "0"
        }
        { bits:   "9:0",
          name:   "TCBP_DIV2",
          desc:   '''Half of the delay between SCL rising and SDA rising in STOP timing, minus 1.
                  This interval is in terms of the IP clock period.
                  '''
          resval: "0"
        }
      ]
    }
    { name:     "CTRL_TIME1",
      desc:     "Controller Timing Parameters 1",
      swaccess: "rw",
      hwaccess: "hro"
      fields: [
        { bits:   "25:16",
          name:   "OD_SCLHI_DIV2",
          desc:   '''Half of the SCL high interval during Open Drain signaling, minus 1.
                  This interval is in terms of the IP clock period.
                  '''
          resval: "0x3ff"
        }
        { bits:   "9:0",
          name:   "OD_SCLLO_DIV2",
          desc:   '''Half of the SCL low interval during Open Drain signaling, minus 1.
                  This interval is in terms of the IP clock period.
                  '''
          resval: "0x3ff"
        }
      ]
    }
    { name:     "CTRL_TIME2",
      desc:     "Controller Timing Parameters 2",
      swaccess: "rw",
      hwaccess: "hro"
      fields: [
        { bits:   "25:16",
          name:   "PP_SCLHI_DIV2",
          desc:   '''Half of the SCL high interval during Push-Pull signaling, minus 1.
                  This interval is in terms of the IP clock period.
                  '''
          resval: "0x3ff"
        }
      ]
    }
    { name:     "CTRL_TIME3",
      desc:     "Controller Timing Parameters 3",
      swaccess: "rw",
      hwaccess: "hro"
      fields: [
        { bits:   "25:16",
          name:   "SDR1_SCLLO_DIV2",
          desc:   '''Half of the SCL low interval during Push-Pull signaling at SDR1 rate, minus 1.
                  This interval is in terms of the IP clock period.

                  This value is scaled in hardware to achieve SDR2-SDR4 rates.
                  '''
          resval: "0x3ff"
        }
        { bits:   "9:0",
          name:   "SDR0_SCLLO_DIV2",
          desc:   '''Half of the SCL low interval during Push-Pull signaling at SDR0 rate, minus 1.
                  This interval is in terms of the IP clock period.
                  '''
          resval: "0x3ff"
        }
      ]
    }
    { name:     "CTRL_TIME4",
      desc:     "Controller Timing Parameters 4",
      swaccess: "rw",
      hwaccess: "hro"
      fields: [
        { bits:   "25:16",
          name:   "FMP_SCLHI_DIV2",
          desc:   '''Half of the SCL high interval during I2C Fast Mode Plus signaling, minus 1.
                  This interval is in terms of the IP clock period.
                  '''
          resval: "0x3ff"
        }
        { bits:   "9:0",
          name:   "FMP_SCLLO_DIV2",
          desc:   '''Half of the SCL low interval during I2C Fast Mode Plus signaling, minus 1.
                  This interval is in terms of the IP clock period.
                  '''
          resval: "0x3ff"
        }
      ]
    }
    { name:     "CTRL_TIME5",
      desc:     "Controller Timing Parameters 5",
      swaccess: "rw",
      hwaccess: "hro"
      fields: [
        { bits:   "25:16",
          name:   "FM_SCLHI_DIV2",
          desc:   '''Half of the SCL high interval during I2C Fast Mode signaling, minus 1.
                  This interval is in terms of the IP clock period.
                  '''
          resval: "0x3ff"
        }
        { bits:   "9:0",
          name:   "FM_SCLLO_DIV2",
          desc:   '''Half of the SCL low interval during I2C Fast Mode signaling, minus 1.
                  This interval is in terms of the IP clock period.
                  '''
          resval: "0x3ff"
        }
      ]
    }
    { name:     "INT_TIME0",
      desc:     '''Interval Timers 0 register.
                Time intervals are specified in microseconds.
                '''
      swaccess: "rw",
      hwaccess: "hro",
      fields: [
        { bits:   "31:16",
          name:   "DEAD_BUS",
          desc:   "Timer interval for Dead Bus condition.",
          resval: "0xc350"
        }
        { bits:   "15:12",
          name:   "CTRL_BUS_AVAIL",
          desc:   "Timer interval for Controller Bus Available condition.",
          resval: "1"
        }
        { bits:   "11:0",
          name:   "READ_STALLED",
          desc:   '''Timer interval for SDA read stalled detection
                  (no Controller SCL activity during Read Transfer).
                  '''
          resval: "0x96"
        }
      ]
    }
    { name:     "INT_TIME1",
      desc:     '''Interval Timers 1 register.
                Time intervals are specified in microseconds.
                '''
      swaccess: "rw",
      hwaccess: "hro",
      fields: [
        { bits:   "31:28",
          name:   "TARG_BUS_AVAIL",
          desc:   "Timer interval for Target Bus Available condition.",
          resval: "1"
        }
        { bits:   "27:24",
          name:   "TARG_TRX_RST",
          desc:   "",
          // TODO: This was set to 0x32; onerous for testing.
          resval: "1"
        }
        { bits:   "23:12",
          name:   "TE0_RECOV",
          desc:   "",
          resval: "0x3c"
        }
        { bits:   "11:0",
          name:   "TARG_BUS_IDLE",
          desc:   "Timer interval for Target Bus Idle condition.",
          resval: "0xc8"
        }
      ]
    }
    { name:     "PHY_CONFIG",
      desc:     "PHY configuration",
      swaccess: "rw",
      hwaccess: "hro",
      fields: [
        { bits:   "31",
          name:   "CTRL_DIRECT_DRIVE_EN",
          desc:   "Enable direct driving of SCL and SDA by software.",
          resval: "0"
        }
        // SCL-related Controller outputs in direct-driving mode.
        { bits:   "27",
          name:   "CTRL_SCL_PP_EN",
          desc:   "Enable push-pull driving of SCL in direct-driving mode, when open rain driving is not also enabled.",
          resval: "0"
        }
        { bits:   "26",
          name:   "CTRL_SCL_OD_EN",
          desc:   "Enable open drain driving of SCL in direct-driving mode.",
          resval: "0"
        }
        { bits:   "25",
          name:   "CTRL_SCL_PU_EN",
          desc:   "Enable pull-up on SCL in direct-driving mode.",
          resval: "0",
        }
        { bits:   "24",
          name:   "CTRL_SCL",
          desc:   "State of SCL line when direct-driving is enabled.",
          resval: "1"
        }
        // SDA-related Controller outputs in direct-driving mode.
        { bits:   "23",
          name:   "CTRL_SDA_PP_EN",
          desc:   "Enable push-pull driving of SDA in direct-driving mode, when open drain driving is not also enabled.",
          resval: "0"
        }
        { bits:   "22",
          name:   "CTRL_SDA_OD_EN",
          desc:   "Enable open drain driving of SDA in direct-driving mode.",
          resval: "0"
        }
        { bits:   "21",
          name:   "CTRL_SDA_PU_EN",
          desc:   "Enable pull-up on SDA in direct-driving mode.",
          resval: "0",
        }
        { bits:   "20",
          name:   "CTRL_SDA",
          desc:   "State of SDA line when direct-driving is enabled.",
          resval: "1"
        }
        { bits:   "1",
          name:   "SDA_HK_EN",
          desc:   "High-keeper enable for SDA.",
          resval: "1"
        }
        { bits:   "0",
          name:   "SCL_HK_EN",
          desc:   "High-keeper enable for SCL.",
          resval: "1"
        }
      ]
    }
    { name:     "BLOCKED_ADDR",
      desc:     '''Blocked target addresses.
                The controller will raise an error if any attempt is made to access a blocked target address.
                This feature is intended to safeguard against inadvertent accesses to any I2C device that may try to employ clock-stretching, but it may also be of use diagnostically.
                ''',
      swaccess: "rw",
      hwaccess: "hro",
      fields: [
        { bits:   "30:24",
          name:   "MASK1",
          desc:   '''Address mask for the second set of blocked addresses.
                  If this field is zero then 'ADDR1' is implicitly not used.
                  '''
          resval: "0"
        }
        { bits:   "22:16",
          name:   "ADDR1",
          desc:   "Second blocked address.",
          resval: "0"
        }
        { bits:   "14:8",
          name:   "MASK0",
          desc:   '''Address mask for the first set of blocked addresses.

                  This mask determines which bits of the device address will be tested and matched against the address in 'ADDR0'.
                  I2C devices are commonly configured with one of a small set of static addresses, differing in only one two address bits.
                  If this field is zero then 'ADDR0' is implicitly not used.
                  '''
          resval: "0"
        }
        { bits:   "6:0",
          name:   "ADDR0",
          desc:   "First blocked address.",
          resval: "0"
        }
      ]
    }
    { name:     "BUFFER_CTRL",
      desc:     "Buffer control",
      hwqe:     "true",
      hwext:    "true",
      fields: [
        { bits:     "31",
          name:     "CLEAR",
          desc:     '''Software clear of buffer state including the following:
                    - All `WPTR` and `RPTR` values are set to the corresponding
                    the `MIN` values, emptying all circular buffers.
                    '''
          swaccess: "wo",
          hwaccess: "hro",
          resval:   "0"
        }
        { bits:     "29:28",
          name:     "SW_ADDR_HI",
          desc:     '''Supplies the high address bits when software performs direct accesses to the
                    internal message buffer.
                    '''
          swaccess: "rw",
          hwaccess: "hrw",
          resval:   "0"
        }
      ]
    }
    { name:     "BUFFER_STATUS",
      desc:     "Buffer status",
      fields: [
        { bits:   "31",
          name:   "HCIQ_ERR",
          desc:   '''Diagnostic error indicator for the HCI queues.
                  The hardware sets this bit in the event of a write to a full or read-only queue, or a read from an empty or write-only queue.
                  Software shall clear this bit by writing '1'.
                  '''
          swaccess: "rw1c",
          hwaccess: "hwo",
          resval:   "0"
        }
        { bits:   "30",
          name:   "TTIQ_ERR",
          desc:   '''Diagnostic error indicator for the TTI queues.
                  The hardware sets this bit in the event of a write to a full or read-only queue, or a read from an empty or write-only queue.
                  Software shall clear this bit by writing '1'.
                  '''
          swaccess: "rw1c",
          hwaccess: "hwo",
          resval:   "0"
        }
      ]
    }

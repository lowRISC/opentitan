      hwext:    "true",
      fields: [
        { bits:   "31",
          name:   "FULL",
          desc:   "Indicates if the queue is full.",
          resval: "0"
        }
        { bits:   "30",
          name:   "PRE",
          desc:   "Indicates if prefetched data is available.",
          resval: "0"
        }
        { bits:   "25:16",

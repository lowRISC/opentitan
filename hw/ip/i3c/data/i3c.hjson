          resval: "0"
        },
        { bits:   "15:0",
          name:   "LIST_SIZE",
          desc:   "List size.",
          resval: "0"
        }
      ]
    },
    { skipto:   "0x180" },
    // Must be aligned to a multiple of 0x10 to implement 4 ports; alignment is important because
    // decoding just extracts address bits.
    { window: {
        name:       "HCI_PORTS",
        desc:       '''HCI ports, occupying successive word addresses:

                    - COMMAND_QUEUE_PORT - Write-only Command Descriptor queue.
                    - RESPONSE_QUEUE_PORT - Read-only Response Descriptor queue.
                    - XFER_DATA_PORT - Read/write data buffer; Rx Data Buffer and Tx Data Buffer.
                    - IBI_PORT - Read-only In-Band Interrupt queue.
                    ''',
        items:      "4",
        validbits:  "32",
        byte-write: "false",
        unusual:    "false",
        swaccess:   "rw"
      }
    }
    { name:     "QUEUE_THLD_CTRL",
      desc:     "Queue Threshold Control.",
      swaccess: "rw",
      hwaccess: "hro",
      fields: [
        { bits:   "31:24",
          name:   "IBI_STATUS_THLD",
          desc:   "IBI Status Threshold.",
          resval: "1"
        }
        { bits:   "23:16",
          name:   "IBI_DATA_SEGMENT_SIZE",
          desc:   "IBI Data Segment Size.",
          resval: "1"
        }
        { bits:   "15:8",
          name:   "RESP_BUF_THLD",
          desc:   "Response Ready Buffer Threshold.",
          resval: "1"
        }
        { bits:   "7:0",
          name:   "CMD_EMPTY_BUF_THLD",
          desc:   "Command Ready Buffer Threshold.",
          resval: "1"
        }
      ]
    }
    { name:     "DATA_BUFFER_THLD_CTRL",
      desc:     "Transfer Data Buffer Threshold Control.",
      swaccess: "rw",
      hwaccess: "hro",
      fields: [
        { bits:   "26:24",
          name:   "RX_START_THLD",
          desc:   '''Receive Start Threshold in DWORDs.
                  Wait until there are at least 2^(N+1) DWORD entries available before starting a Read Transfer.
                  '''
          resval: "1"
        },
        { bits:   "18:16",
          name:   "TX_START_THLD",
          desc:   '''Transmit (Transfer) Start Threshold in DWORDs.
                  Wait until there are at least 2^(N+1) DWORDs of data available before starting a Write Transfer.
                  '''
          resval: "1"
        },
        { bits:   "10:8",
          name:   "RX_BUF_THLD",
          desc:   '''Receive Buffer Threshold.
                  Interrupt triggers when there are at least 2^(N+1) Rx Buffer DWORDs of data available.
                  ''',
          resval: "1"
        }
        { bits:   "2:0",
          name:   "TX_BUF_THLD",
          desc:   '''Transmit Buffer Threshold.
                  Interrupt triggers when there are at least 2^(N+1) Tx Buffer DWORD entries available.
                  ''',
          resval: "1"
        }
      ]
    }
    { name:     "QUEUE_SIZE",

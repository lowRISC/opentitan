    { name:     "TARG_QUEUE_THLD_CTRL",
      desc:     "Target-side control register for setting queue interrupt thresholds.",
      swaccess: "rw",
      hwaccess: "hro",
      fields: [
        { bits:   "31:24",
          name:   "IBI_STATUS_THLD",
          desc:   "IBI Status Threshold.",
          resval: "1"
        }
        { bits:   "15:8",
          name:   "RX_DESC_THLD",
          desc:   '''Rx Descriptor Queue Threshold.
                  Interrupt is issued when the Rx Descriptor Queue contains at least N entries.
                  0: Do not raise an interrupt.
                  ''',
          resval: "1"
        }
      ]
    }
    { name:     "TARG_QUEUE_STATUS_LEVEL",
      desc:     "Target-side queue levels.",
      swaccess: "ro",
      hwaccess: "hwo",
      hwext:    "true",
      fields: [
        { bits:   "31:24",
          name:   "IBI_FREE_LVL",
          desc:   "The available space (in DWORDs) in the Target IBI queue."
        }
        { bits:   "23:16",
          name:   "ASYNC_EVT_LVL",
          desc:   "The number of Asynchronous Event descriptors in the queue."
        }
        { bits:   "15:8",
          name:   "RX_DESC_LVL",
          desc:   "The number of descriptors present in the Rx Descriptor queue."
        }
        { bits:   "7:0",
          name:   "RX_BUF_LVL",
          desc:   "The number of DWORDs of data present in the Rx Buffer."
        }
      ]
    }
    { name:     "TARG_BUF_THLD_CTRL",
      desc:     "Target-side control register for setting buffer interrupt thresholds.",
      swaccess: "rw",
      hwaccess: "hro",
      fields: [
        { bits:   "30:28",
          name:   "RX_START_THLD",
          desc:   '''Receive Start Threshold in DWORDs.
                  Wait until there are at least 2^(N+1) DWORD entries available before starting a Read Transfer.
                  '''
          resval: "1"
        }
        { bits:   "27:24",
          name:   "RX_BUF_THLD",
          desc:   '''Receive Buffer Threshold.
                  Interrupt triggers when there are at least N+1 Rx Buffer DWORDs of data available.
                  ''',
          resval: "1"
        }
        { bits:   "11:0",
          name:   "RX_SEGMENT_SIZE",
          desc:   '''Maximum length of received data segment, minus 1.
                  Received data is divided into DWORDs of no more than this length.
                  '''
          resval: "1"
        }
      ]
    }
    { multireg: {
        name:     "TARG_RW_LEN",
        desc:     "Target Read/Write Length.",
        count:    "MaxTargets",
        cname:    "TARGET",
        swaccess: "rw",
        hwaccess: "hrw",
        fields: [
          { bits:   "31:16",
            name:   "MWL",
            desc:   "Maximum Write transfer Length, in bytes.",
            resval: "0xffff"
          }
          { bits:   "15:0",
            name:   "MRL",
            desc:   "Maximum Read transfer Length, in bytes.",
            resval: "0xffff"
          }
        ]
      }
    }
    { multireg: {
        name:     "TARG_IBI_LEN",
        desc:     "Target IBI payload Length.",
        count:    "MaxTargets",
        cname:    "TARGET",
        hwaccess: "hrw",
        fields: [
          { bits:     "7:0",
            name:     "IBI_LEN",
            desc:     "Maximum length of IBI data payload, in bytes.",
            swaccess: "rw",
            resval:   "0xff"
          }
        ]
      }
    }
    { multireg: {
        name:     "TARG_EVENT_ENABLE",
        desc:     "Target Event enables.",
        count:    "MaxTargets",
        cname:    "TARGET",
        swaccess: "ro",
        hwaccess: "hrw",
        fields: [
          { bits:     "2",
            name:     "ENHJ",
            desc:     "If 1 then Hot-Join requests are enabled for this Target.",
            resval:   "1",
          }
          { bits:     "1",
            name:     "ENCR",
            desc:     "If 1 then Controller Role Requests are enabled for this Target.",
            resval:   "1",
          }
          { bits:     "0",
            name:     "ENINT",
            desc:     "If 1 then In-Band Interrupts are enabled for this Target.",
            resval:   "1",
          }
        ]
      }
    }
    { name:     "TARG_STATE_DEBUG",
      swaccess: "ro",
      hwaccess: "hwo",
      hwext:    "true",
      desc:     "Target State Debug",
      fields: [
        { bits:   "31:24",
          name:   "TRX_STATE",
          desc:   "Transceiver state.",
          resval: "0",
        }
        { bits:   "23:16",
          name:   "FSM_STATE",
          desc:   "Core FSM state.",
          resval: "0",
        }
        { bits:   "15:12",
          name:   "BUS_MODE",
          desc:   "Current bus mode.",
          resval: "0",
        }
        { bits:   "9",
          name:   "BUS_IDLE",
          desc:   "Reports whether the Bus Idle condition is met at this instant.",
          resval: "0"
        }
        { bits:   "8",
          name:   "BUS_AVAIL",
          desc:   "Reports whether the Bus Available condition is met at this instant.",
          resval: "0"
        }
        { bits:   "1",
          name:   "SDA_LINE_SIGNAL_LEVEL",
          desc:   "SDA Line Signal Level.",
          resval: "1"
        }
        { bits:   "0",
          name:   "SCL_LINE_SIGNAL_LEVEL",
          desc:   "SCL Line Signal Level.",
          resval: "1"
        }
      ]
    }
    { multireg: {
        name:     "TARG_ENABLE",
        count:    "MaxTargets",
        cname:    "TARGET",
        compact:  "true",
        desc:     "Enable signals for individual virtual targets.",
        swaccess: "rw",
        hwaccess: "hro",
        fields: [
          { bits:   "0",
            name:   "ENABLE",
            desc:   '''Enable virtual target.
                    A disabled target will not participate in address assignment or respond to bus traffic.
                    '''
            resval: "0"
          }
        ]
      }
    }
    { multireg: {
        name:     "TARG_GROUP",
        count:    "MaxGroups"
        cname:    "GROUP"
        desc:     "Group addressing configuration.",
        swaccess: "ro",
        hwaccess: "hrw",
        fields: [
          { bits:   "15:8",
            name:   "TARGETS",
            desc:   '''The set of virtual targets subscribed to this group address.
                    If zero, this entry in the list of group addresses is unused.
                    ''',
            resval: "0"
          }
          { bits:   "6:0",
            name:   "GROUP_ADDR",
            desc:   '''Group addresss, iff the entry is used.
                    If zero, and TARGETS is non-zero, all I3C traffic will be captured as if addressed to the selected Target(s).
                    '''
            resval: "0"
          }
        ]
      }
    }
    { multireg: {
        name:     "TARG_TX_THLD_CTRL",
        desc:     "Target control register for setting Tx thresholds.",
        count:    "MaxTargets",
        cname:    "TARGET",
        swaccess: "rw",
        hwaccess: "hro",
        fields: [
          { bits:   "18:16",
            name:   "TX_START_THLD",
            desc:   '''Transmit (Transfer) Start Threshold in DWORDs.
                    Wait until there are at least 2^(N+1) DWORDs of data available before starting a Write Transfer.
                    '''
            resval: "1"
          }
          { bits:   "15:8",
            name:   "TX_DESC_EMPTY_THLD",
            desc:   '''Tx Descriptor Queue Threshold.
                    Interrupt is issued when the Tx Descriptor Queue contains at least N empty entries.
                    0: Do not raise an interrupt.
                    ''',
            resval: "1"
          }
          { bits:   "7:0",
            name:   "TX_BUF_THLD",
            desc:   '''Transmit Buffer Threshold.
                    Interrupt triggers when there are at least N+1 Tx Buffer DWORD entries available.
                    ''',
            resval: "1"
          }
        ]
      }
    }
    { multireg: {
        name:     "TARG_TX_QUEUE_STATUS_LEVEL",
        desc:     "Target status register reporting transmit queue levels.",
        count:    "MaxTargets",
        cname:    "TARGET",
        swaccess: "ro",
        hwaccess: "hwo",
        hwext:    "true",
        fields: [
          { bits:   "15:8",
            name:   "TX_DESC_FREE_LVL",
            desc:   "The number of free Tx Descriptor Queue entries."
          }
          { bits:   "7:0",
            name:   "TX_BUF_FREE_LVL",
            desc:   "The number of free DWORDs in the Tx Buffer."
          }
        ]
      }
    }
    { multireg: {
        name:     "TARG_ADDR",
        desc:     "Target I3C addresses.",
        count:    "MaxTargets",
        cname:    "TARGET",
        swaccess: "rw",
        fields: [
          { bits:     "31",
            name:     "DYNAMIC_ADDR_VALID",
            desc:     "Dynamic Address is Valid.",
            hwaccess: "hrw",
            resval:   "0"
          }
          { bits:     "22:16",
            name:     "DYNAMIC_ADDR",
            desc:     "Device Dynamic Address.",
            hwaccess: "hrw",
            resval:   "0"
          }
          { bits:     "15",
            name:     "STATIC_ADDR_VALID",
            desc:     "Static Addres is Valid.",
            hwaccess: "hro",
            resval:   "0"
          }
          { bits:     "6:0",
            name:     "STATIC_ADDR",
            desc:     "Device Static Address.",
            hwaccess: "hro",
            resval:   "0"
          }
        ]
      }
    }
    { multireg: {
        name:     "TARG_CHAR",
        desc:     "Target Characteristics.",
        count:    "MaxTargets",
        cname:    "TARGET",
        swaccess: "rw",
        hwaccess: "hro",
        fields: [
          { bits:   "31:24",
            name:   "BCR",
            desc:   "Bus Characteristics Register.",
            resval: "0x3e"
          }
          { bits:   "23:16",
            name:   "DCR",
            desc:   "Device Characteristics Register.",
            resval: "0"
          }
          { bits:   "15:0",
            name:   "PID_HI",
            desc:   "High part of Provisioned ID.",
            resval: "0"
          }
        ]
      }
    }
    { multireg: {
        name:     "TARG_PID_LO",
        desc:     "Low parts of Target Provisioned IDs.",
        count:    "MaxTargets",
        cname:    "TARGET",
        swaccess: "rw",
        hwaccess: "hro",
        fields: [
          { bits:   "31:0",
            name:   "PID_LO",
            desc:   "Low part of Provisioned ID.",
            resval: "0"
          }
        ]
      }
    }
    { multireg: {
        name:     "TARG_CAPS",
        desc:     "Target Capabilities.",
        count:    "MaxTargets",
        cname:    "TARGET",
        swaccess: "rw",
        hwaccess: "hro",
        fields: [
          { bits:     "13",
            name:     "VTCAP1_SHARED_DET",
            desc:     "Shared Peripheral Detect.",
            resval:   "0"
          }
          { bits:     "12",
            name:     "VTCAP1_SIDE_FX",
            desc:     "Side Effects.",
            resval:   "0",
          }
          { bits:     "10:8",
            name:     "VTCAP1_TYPE",
            desc:     "Virtual Target Type.",
            resval:   "0"
          }
          { bits:     "4:0",
            name:     "VTCAP2",
            desc:     "The defined bits of the VTCAP2 byte.",
            resval:   "0"
          }
        ]
      }
    }
    { multireg: {
        name:     "TARG_INFO",
        desc:     "Target information.",
        count:    "MaxTargets",
        cname:    "TARGET",
        swaccess: "ro",
        fields: [
          { bits:     "11",
            name:     "ENDXFER_CAND_CRC_EARLY",
            desc:     "Candidate setting for 'CRC Word Indicator.'",
            hwaccess: "hrw",
            resval:   "1"
          }
          { bits:     "10",
            name:     "ENDXFER_CAND_WR_EARLY_TERM",
            desc:     "Candidate setting for 'Enable WRITE Early Termination Request.'",
            hwaccess: "hrw",
            resval:   "0"
          }
          { bits:     "8",
            name:     "ENDXFER_CAND_WR_NACK",
            desc:     "Candidate setting for 'Enable ACK/NACK Capability for WRITE Comamnd.'",
            hwaccess: "hrw",
            resval:   "0"
          }
          { bits:     "5",
            name:     "ENDXFER_CRC_EARLY",
            desc:     "CRC Word Indicator.",
            hwaccess: "hrw",
            resval:   "1"
          }
          { bits:     "4",
            name:     "ENDXFER_WR_EARLY_TERM",
            desc:     "Enable WRITE Early Termination Request.",
            hwaccess: "hrw",
            resval:   "0"
          }
          { bits:     "3",
            name:     "ENDXFER_WR_NACK",
            desc:     "Enable ACK/NACK Capability for WRITE Command.",
            hwaccess: "hrw",
            resval:   "0"
          }
          { bits:     "1:0",
            name:     "AS",
            desc:     "Activity State (ENTASn).",
            hwaccess: "hwo",
            resval:   "0"
          }
        ]
      }
    }
    { multireg: {
        name:     "TARG_MAX_RDWR",
        desc:     "Target Maximum Read/Write Rate and Turnaround.",
        count:    "MaxTargets",
        cname:    "MAX_RDWR",
        swaccess: "rw",
        hwaccess: "hro",
        fields: [
          { bits:   "31:28",
            name:   "RDTURN_SCALE",
            desc:   '''Maximum Read Turnaround Time Scale.

                    This value scales the Turnaround Time Value, giving the Maximum Read Turnaround Time in microseconds.
                    max time = RDTURN_VAL << (RDTURN_SCALE + 1)
                    ''',
            resval: "0"
          }
          { bits:   "27:16",
            name:   "RDTURN_VAL",
            desc:   "Maximum Read Turnaround Time Value.",
            resval: "1"
          }
          { bits:   "15:8",
            name:   "MAXWR",
            desc:   "Maximum Write Settings.",
            resval: "0"
          }
          { bits:   "6:0",
            name:   "MAXRD",
            desc:   "Maximum Read Settings",
            resval: "0"
          }
        ]
      }
    }
    // Leave some space for additional registers before the TTI ports window starts.
    { skipto: "0x3a0" },
    // Must be aligned to a multiple of 0x40 to implement 16 ports; alignment is important because
    // decoding just extracts address bits.
    { window: {
        name:       "TTI_PORTS",
        desc:       '''TTI ports, occupying successive word addresses:

                    - Rx Descriptor Queue.
                    - Rx Data Buffer.
                    - IBI Status Descriptor.
                    - IBI Data Buffer.
                    - Asynchronous Event Queue.
                    - Target 0-3 Tx Descriptor Queue.
                    - Target 0-3 Tx Data Buffer.
                    ''',
        items:      "13",
        validbits:  "32",
        byte-write: "false",
        unusual:    "true",  // Not 2^N words.
        swaccess:   "rw"
      }
    }
    // Terminator for the linked list of Extended Capabilities.
    { name:     "TERM_EXTCAP_HEADER",
      desc:     "Terminating Extended Capability Header",
      swaccess: "ro",
      hwaccess: "hwo",
      hwext:    "true",
      fields: [
        { bits:   "23:8",
          name:   "CAP_LENGTH",
          desc:   "Capability Structure Length in DWORDs.",
          resval: "0x01"
        }
        { bits:   "7:0",
          name:   "CAP_ID",
          desc:   "Extended Capability ID",
          resval: "0x00"
        }
      ]
    }
    { skipto: "0x500" },
    { window: {
        name:       "DAT",
        desc:       "Device Address Table.",
        items:      "NumDATWords",
        validbits:  "32",
        unusual:    "false",
        byte-write: "false",
        swaccess:   "rw"
      }
    }
    { window: {
        name:       "DCT",
        desc:       "Device Characteristics Table.",
        items:      "NumDCTWords",
        validbits:  "32",
        byte-write: "false",
        unusual:    "false",
        swaccess:   "rw"
      }
    }
    // This window onto the entire message buffer is optionally included based on 'SWDirectMsgBuf'.
    // - Up to 512 words of the message buffer may be accessed at a time, with any additional upper
    //   address bits being specified by the `BUFFER_CTRL.SW_ADDR_HI` register field.
    { window: {
        name:       "BUFFER",
        items:      "512",
        validbits:  "32",
        byte-write: "false",
        unusual:    "false"
        swaccess:   "rw",
        desc:       "Software-managed 2KiB message buffer used for transmitting and receiving messages."
      }
    }
  ]
}

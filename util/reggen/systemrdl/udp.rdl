/* Multibit boolean */
property mubi {
  type = boolean;
  component = field;
  default = false;
};

/* ‘true’ if hardware uses ‘re’ signal, which is latched signal of software read pulse. */
property hwre {
  type = boolean;
  component = reg;
  default = false;
};

/* If it is set to true, the register will be implemented using the prim_subreg_shadow module.
 * Shadow registers are a mechanism to guard sensitive registers against this specific type 
 * of attack. They come at a cost of increased area, and a modified SW interaction.
 * Usage of shadow registers should be evaluated with this impact in mind.
 */
property shadowed {
  type = boolean;
  component = reg;
  default = false;
};

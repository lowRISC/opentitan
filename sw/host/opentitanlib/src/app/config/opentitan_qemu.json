{
  "interface": "qemu",
  "pins": [
      // Resetting is done through the monitor on QEMU, but OpenTitanTool
      // expects a pin. We map a pin-like interface to ID 255 which can be used
      // to send reset commands to QEMU when pulled up and down.
      {
        "name": "RESET",
        "alias_of": "255",
        "level": true,
      },
      // VBUS control currently has to go through a special QEMU chardev because
      // QEMU does not yet implement a real pinmux.
      {
        "name": "VBUS_SENSE_EN",
        "alias_of": "254",
        "level": false,
      }
  ],
  "strappings": [
    {
      "name": "RESET",
      "pins": [
        {
          "name": "RESET",
          "level": false
        }
      ]
    }
  ],
  "uarts": [
    {
      "name": "console",
      "alias_of": "0"
    }
  ],
  "provides": {
    "chip": "opentitan",
  }
}

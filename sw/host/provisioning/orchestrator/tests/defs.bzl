load("@lowrisc_opentitan//rules/opentitan:exec_env.bzl", "ExecEnvInfo")
load("@lowrisc_opentitan//rules/opentitan:defs.bzl", "hacky_tags")

def _orchestrator_bitstream_transition_impl(settings, attr):
    return {
        "//hw/bitstream/universal:otp": attr.otp,
        "//hw/bitstream/universal:env": attr.exec_env,
    }

_orchestrator_bitstream_transition = transition(
    implementation = _orchestrator_bitstream_transition_impl,
    inputs = [],
    outputs = [
        "//hw/bitstream/universal:otp",
        "//hw/bitstream/universal:env",
    ],
)

def _orchestrator_fpga_test_impl(ctx):
    # Executable for test rules must be generated by the same rule, so we
    # create a symbolic link here.
    out = ctx.actions.declare_file(ctx.label.name)
    ctx.actions.symlink(
        output = out,
        target_file = ctx.file.src,
        is_executable = True,
    )

    # Runfiles propagation
    dep_attrs = [
        ctx.attr.src,
        ctx.attr.orchestrator,
        ctx.attr.orchestrator_cfg,
        ctx.attr.data,
    ]
    deps = []
    for attr in dep_attrs:
        if type(attr) != "list":
            attr = [attr]
        deps.extend(attr)
    runfiles = []
    for target in deps:
        runfiles.extend(target[DefaultInfo].files.to_list())
        runfiles.extend(target[DefaultInfo].default_runfiles.files.to_list())

    # Exposing path to scripts
    env = {}
    for key, value in ctx.attr.env.items():
        env[key] = ctx.expand_location(value, deps)
    env["ORCHESTRATOR_PATH"] = ctx.executable.orchestrator.short_path
    env["SKU_CONFIG_PATH"] = ctx.file.orchestrator_cfg.short_path

    return [
        DefaultInfo(
            executable = out,
            files = depset([out]),
            runfiles = ctx.runfiles(files = runfiles),
        ),
        testing.TestEnvironment(env),
    ]

_orchestrator_fpga_test = rule(
    implementation = _orchestrator_fpga_test_impl,
    attrs = {
        "src": attr.label(
            allow_single_file = True,
            doc = "The bash script to execute for the test.",
        ),
        "env": attr.string_dict(
            doc = "Additional environment variables to set for the test.",
        ),
        "data": attr.label_list(
            allow_files = True,
            doc = "Additional data dependencies for the test.",
        ),
        "orchestrator_cfg": attr.label(
            allow_single_file = True,
            doc = "The SKU configuration file for the orchestrator. This will be exported to the SKU_CONFIG_PATH environment variable.",
        ),
        "orchestrator": attr.label(
            executable = True,
            cfg = _orchestrator_bitstream_transition,
            doc = "The orchestrator tool to test. This will be exported to the ORCHESTRATOR_PATH environment variable.",
        ),
        "otp": attr.label(
            allow_single_file = True,
            doc = "OTP image for this test",
            default = "//hw/top_earlgrey/data/otp/emulation:otp_img_test_unlocked0_manuf_empty",
        ),
        "exec_env": attr.label(
            providers = [ExecEnvInfo],
            doc = "Execution environment for this test",
        ),
        "_allowlist_function_transition": attr.label(
            default = "@bazel_tools//tools/allowlists/function_transition_allowlist",
        ),
    },
    test = True,
)

def orchestrator_test(name, skus, exec_env, env = {}, tags = [], **kwargs):
    """
    Instantiates an orchestrator test per SKU and execution environment.

    Each test target is named `{name}_{sku}_{exec_env_suffix}`.

    Args:
      name: The base name of the test.
      skus: A dictionary of SKU configurations.
      exec_env: A list of labels for execution environments.
      env: Additional environment variables for the test.
      tags: Additional tags for the test.
      **kwargs: Additional arguments for the underlying _orchestrator_fpga_test rule.
    """
    for sku, cfg in skus.items():
        sku_tags = tags + cfg.get("tags", []) + [
            "changes_otp",
            "exclusive",
            "manuf",
            "provisioning",
        ]
        if cfg.get("offline", False):
            sku_tags.append("manual")

        for exec_env_label in exec_env:
            (_, suffix) = exec_env_label.split(":")
            env_tags = hacky_tags(exec_env_label)
            if "fpga" not in env_tags:
                fail("NotImplementedError: Only FPGA execution environments are supported for orchestrator tests.")
            if "cw310" in env_tags:
                fpga = "cw310"
            elif "cw340" in env_tags:
                fpga = "cw340"
            else:
                fail("Unable to identify FPGA kind from exec_env:", exec_env_label)
            _orchestrator_fpga_test(
                name = "{}_{}_{}".format(name, sku, suffix),
                exec_env = exec_env_label,
                env = env | {"FPGA": fpga},
                orchestrator_cfg = cfg["orchestrator_cfg"],
                tags = sku_tags + env_tags,
                **kwargs
            )

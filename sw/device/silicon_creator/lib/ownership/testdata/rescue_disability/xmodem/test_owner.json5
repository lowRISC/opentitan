{
  config_version: 1,
  update_mode: "Open",
  sram_exec: "DisabledLocked",
  min_security_version_bl0: "NoChange",

  ownership_key_alg: "EcdsaP256",
  owner_key: {
    Ecdsa: "sw/device/silicon_creator/lib/ownership/keys/fake/owner_ecdsa_p256.pub.der"
    // Opentitantool will load this DER file and transform the key into the
    // little-endian representation of the x/y cooridiantes.
    //
    // Ecdsa: {
    //   x: "<hex string>",
    //   y: "<hex string>"
    // }
  },
  activate_key: {
    Ecdsa: "sw/device/silicon_creator/lib/ownership/keys/fake/activate_ecdsa_p256.pub.der"
  },
  unlock_key: {
    Ecdsa: "sw/device/silicon_creator/lib/ownership/keys/fake/unlock_ecdsa_p256.pub.der"
  },
  data: [
    {
      ApplicationKey: {
        header: {
          identifier: "ApplicationKey",
          length: 0
        },
        key_alg: "EcdsaP256",
        key_domain: "Prod",
        usage_constraint: 0,
        key: {
          Ecdsa: "sw/device/silicon_creator/lib/ownership/keys/fake/app_prod_ecdsa_p256.pub.der"
        }
      }
    },
    {
      ApplicationKey: {
        header: {
          identifier: "ApplicationKey",
          length: 0
        },
        key_alg: "EcdsaP256",
        key_domain: "Dev",
        usage_constraint: 0,
        key: {
          Ecdsa: "sw/device/silicon_creator/lib/ownership/keys/fake/app_dev_ecdsa_p256.pub.der"
        }
      }
    },
    {
      ApplicationKey: {
        header: {
          identifier: "ApplicationKey",
          length: 0
        },
        key_alg: "EcdsaP256",
        key_domain: "Test",
        usage_constraint: 0,
        key: {
          Ecdsa: "sw/device/silicon_creator/lib/ownership/keys/fake/app_test_ecdsa_p256.pub.der"
        }
      }
    },
    {
      // The Rescue Config determines whether the ROM_EXT rescue protocol
      // is enabled and what rescue and boot service commands are permitted.
      "RescueConfig": {
        "protocol": "Xmodem",
        "trigger": "UartBreak",
        "trigger_index": 0,
        "gpio_pull_en": false,
        "gpio_value": false,
        "timeout": 0,
        "enter_on_failure" : false,
        "start": 32,
        "size": 206,
        "command_allow": [
          // Disallowed all the commands.
        ]
      }
    }
  ],
}

// NIST ACVP ML-DSA-87 sign vector #61 (first ML-DSA-87 vector):
// https://github.com/usnistgov/ACVP-Server/tree/master/gen-val/json-files/ML-DSA-sigGen-FIPS204

{
  "entrypoint": "main",
  "input": {
    "dmem": {
      // Arithmetically shared first signature polynomial Z[0].
      "_sec_bound_check_x0_pos": "",
      "_sec_bound_check_x1_pos": "",

      // First coefficient is set to the boundary value 2^19 - 120, which will fail the norm check, Z[0][0] = 0x0007ff88.
      "_sec_bound_check_x0_neg": "",
      "_sec_bound_check_x1_neg": "",

    }
  },
  "output": {
    "dmem": {
      "_sec_bound_check_res_pos": "0xffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffff",
      "_sec_bound_check_res_neg": "0xffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffff",
    }
  }
}

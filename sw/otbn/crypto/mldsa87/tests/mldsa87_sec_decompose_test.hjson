// NIST ACVP ML-DSA-87 sign vector #61 (first ML-DSA-87 vector):
// https://github.com/usnistgov/ACVP-Server/tree/master/gen-val/json-files/ML-DSA-sigGen-FIPS204

{
  "entrypoint": "main",
  "input": {
    "dmem": {
      // First commmitment polynomial W[0].
      "_sec_decompose_w_s0": "",
      "_sec_decompose_w_s1": "",
    }
  },
  "output": {
    "dmem": {
      // W0[0] unmasked.
      "_sec_decompose_w_s0": "",
      // W1
      "_sec_decompose_w1": "",
    }
  }
}

      // NTT(C)
      "_compute_r0_c": "",

      // Encoded S2 (share 0)
      "_compute_r0_s2_share0": "",
      // Encoded S2 (share 1)
      "_compute_r0_s2_share1": "",
     }
  },

  "output": {

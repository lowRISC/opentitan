      // RHO
      "mldsa87_keygen_pk_rho": "0x3be2bf0525ab66440f1dee71ba64ba907f482dc9ad212ff59afea8c21c4b2d8c",

      // T1
      "mldsa87_keygen_pk_t1": "",

      //
      // Secret key
      //

      // RHO_PRIME
      "mldsa87_keygen_sk_rho_prime_share0": "0x72ae7d73ab7a966000c042d98864c5475fb737a04edba1f4537b69d3329c9ccd32628a1a51153331fb49a97f20b3cd84d0154651d04e60c6f89fb5a9661ae1a0",

      // K
      "mldsa87_keygen_sk_k_share0": "0x090361e7a6856acad3369b45717db5202c1a31b47a144f25f82b733724dcf3b6",

      // TR
      "mldsa87_keygen_sk_tr": "0xe5da6a329c5c0994baf12e40b3ad7f8b550026b9881b0669089ed5f4821f8d2bee441be193ac4f292563c554f3bafa42abbeac1a9a62949463b0b7d80eb4ecc7",

      // S1
      "mldsa87_keygen_sk_s1_share0": "",

      // S2
      "mldsa87_keygen_sk_s2_share0": "",

      // T0
      "mldsa87_keygen_sk_t0": "",
    }
  }
}

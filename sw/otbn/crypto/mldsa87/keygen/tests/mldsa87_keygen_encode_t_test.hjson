// NIST ACVP ML-DSA-87 keygen vector #51 (first ML-DSA-87 vector):
// https://github.com/usnistgov/ACVP-Server/blob/master/gen-val/json-files/ML-DSA-keyGen-FIPS204

{
  "entrypoint": "main",
  "input": {
    "dmem": {
      // T[0] (share 0)
      "_encode_t_t0_share0": "",
      // T[1] (share 0)
      "_encode_t_t1_share0": "",
      // T[2] (share 0)
      "_encode_t_t2_share0": "",
      // T[3] (share 0)
      "_encode_t_t3_share0": "",
      // T[4] (share 0)
      "_encode_t_t4_share0": "",
      // T[5] (share 0)
      "_encode_t_t5_share0": "",
      // T[6] (share 0)
      "_encode_t_t6_share0": "",
      // T[7] (share 0)
      "_encode_t_t7_share0": "",

      // T[0] (share 1)
      "_encode_t_t0_share1": "",
      // T[1] (share 1)
      "_encode_t_t1_share1": "",
      // T[2] (share 1)
      "_encode_t_t2_share1": "",
      // T[3] (share 1)
      "_encode_t_t3_share1": "",
      // T[4] (share 1)
      "_encode_t_t4_share1": "",
      // T[5] (share 1)
      "_encode_t_t5_share1": "",
      // T[6] (share 1)
      "_encode_t_t6_share1": "",
      // T[7] (share 1)
      "_encode_t_t7_share1": "",

    }
  },
  "output": {
    "dmem": {
      // Encoded T0
      "_encode_t_t0_enc": "",
      // Encoded T1
      "_encode_t_t1_enc": "",
    }
  },
}

// NIST ACVP ML-DSA-87 verify vector #63 (first ML-DSA-87 vector with a
// positive verification result):
// https://github.com/usnistgov/ACVP-Server/tree/master/gen-val/json-files/ML-DSA-sigVer-FIPS204

{
  "entrypoint": "main",
  "input": {
    "dmem": {
      // Signature polynomial Z[0].
      "_check_infinity_norm_poly_good": "",
      // Signature polynomial Z[0] with an out-of-bounds first coefficient, i.e., Z[0][0] >= 2^19 - BETA.
      "_check_infinity_norm_poly_bad": "",
    }
  },
  "output": {
    "dmem": {
       "_check_infinity_norm_res_good": "0xffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffff",
       "_check_infinity_norm_res_bad": "0xffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffff",
     }
  }
}

      "w1": "0x511c6d4e0765ecec159b8a9f23a3c244855709e2a3168189ed2c9cb0b40b604b",
      "w2": "0x000000000000000000000000000000000000000000000000b69feb285fed6e57",
      # [w5, w4, w3] is the second share d1 of the hidden scalar d
      "w3": "0xe16d9a8573f2d77f7ff8d836b6a724f4beaaf10ed7609dfaee412ffd413985ad",
      "w4": "0xbef4ceb3c6baed3cfd622f9733fe2986f9a74e75106ade419a1717748e8d9d57",
      "w5": "0x00000000000000000000000000000000000000000000000076b27cd6c20f98dc",
    }
  }
}

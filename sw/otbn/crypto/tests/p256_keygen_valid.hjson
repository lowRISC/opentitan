{
  /**
   * @param[out] dmem[d0]: First share of secret key.
   * @param[out] dmem[d1]: Second share of secret key.
   * @param[out]  dmem[x]: Public key x-coordinate.
   * @param[out]  dmem[y]: Public key y-coordinate.
   */

  "input": {
    "dmem": {
      "mode": "0x00000497"  # MODE_KEYGEN
    }
  }
  "output": {
    "dmem": {
      # Verified that (x, y) == (d0 + d1) * G
      "x": "0x1944eab489dcd84bd9655e0c32bea8c1037324dbdc3c7894c4cccfbebaf53e41"
      "y": "0xd16ed98d823f9f720127d898075c16aab043838504a2ab44568a22446c66695d"

      "d0":
        '''
          0x0000000000000000000000000000000000000000000000009a913f5c160d45c8
            9561a96adbad3405e8e4123669cf56682c66b3f45461337ea43add26f8f1023d

        '''

      "d1":
        '''
          0x000000000000000000000000000000000000000000000000d03e850f6f57a542
            ab1cd35bf9af844dc128b5e45c930292ca6833285928688144672f7b7d037184
        '''
    }
  }
}

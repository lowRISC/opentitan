{
  /**
   * @param[out] dmem[d0]: First share of secret key.
   * @param[out] dmem[d1]: Second share of secret key.
   * @param[out]  dmem[x]: Public key x-coordinate.
   * @param[out]  dmem[y]: Public key y-coordinate.
   */

  "input": {
    "dmem": {
      "mode": "0x00000497"  # MODE_KEYGEN
    }
  }
  "output": {
    "dmem": {
      # Verified that (x, y) == (d0 + d1) * G
      "x": "0xac84a3a3ab1831a7ad132f1e18419c9cfdec84ff851c24160c7322325d129654"
      "y": "0x5218f78a1c9cde837bb474abe02eea37950f6734b3afe3352ecb47fc6ed6ab98"

      "d0":
        '''
          0x0000000000000000000000000000000000000000000000002e828509651d4b06
            a8d4ecc816960348c15d715057b4feebf3c5023a21a0f47fa7f66111cae4f57a
        '''

      "d1":
        '''
          0x000000000000000000000000000000000000000000000000779c02cad160ed8a
            78cda582ef8472c675957cc92b6006a87cb03e8c1788b1abe09bdc259ec37cc6
        '''
    }
  }
}

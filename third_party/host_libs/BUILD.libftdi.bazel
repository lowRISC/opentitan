load("@rules_foreign_cc//foreign_cc:cmake.bzl", "cmake")

package(default_visibility = ["//visibility:public"])

filegroup(
    name = "all_srcs",
    srcs = glob(["**"]),
)

cmake(
    name = "libftdi",
    cache_entries = {
        "STATICLIBS": "ON",
        "SHAREDLIBS": "OFF",
        "FTDI_EEPROM": "OFF",
        "EXAMPLES": "OFF",
        "DOCUMENTATION": "OFF",
        "PYTHON_BINDINGS": "OFF",
    },
    copts = [
        "-fPIC",
        "-Wno-error",
    ],
    lib_source = ":all_srcs",
    out_static_libs = ["libftdi1.a"],
    deps = [
        "@lowrisc_opentitan//third_party/host_libs:usb",
    ],
)

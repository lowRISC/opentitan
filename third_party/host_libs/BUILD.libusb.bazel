load("@rules_cc//cc:defs.bzl", "cc_library")

package(default_visibility = ["//visibility:public"])

genrule(
    name = "gen_config_h",
    outs = ["config.h"],
    cmd = """
    cat << 'EOF' > $@
#define HAVE_ASM_TYPES_H 1
#define HAVE_CLOCK_GETTIME 1
#define HAVE_DECL_EFD_CLOEXEC 1
#define HAVE_DECL_EFD_NONBLOCK 1
#define HAVE_DECL_TFD_CLOEXEC 1
#define HAVE_DECL_TFD_NONBLOCK 1
#define HAVE_DLFCN_H 1
#define HAVE_EVENTFD 1
#define HAVE_INTTYPES_H 1
#define HAVE_NFDS_T 1
#define HAVE_PIPE2 1
#define HAVE_PTHREAD_CONDATTR_SETCLOCK 1
#define HAVE_PTHREAD_SETNAME_NP 1
#define HAVE_STDINT_H 1
#define HAVE_STDIO_H 1
#define HAVE_STDLIB_H 1
#define HAVE_STRINGS_H 1
#define HAVE_STRING_H 1
#define HAVE_STRUCT_TIMESPEC 1
#define HAVE_SYSLOG 1
#define HAVE_SYS_STAT_H 1
#define HAVE_SYS_TIME_H 1
#define HAVE_SYS_TYPES_H 1
#define HAVE_TIMERFD 1
#define HAVE_UNISTD_H 1
#define PLATFORM_POSIX 1
#define _GNU_SOURCE 1
#define HAVE_LIBUDEV 1
#define USE_UDEV 1
#define DEFAULT_VISIBILITY __attribute__((visibility("default")))
#define PRINTF_FORMAT(a, b) __attribute__((__format__(__printf__, a, b)))
#define PACKAGE_VERSION "1.0.26"
EOF
    """,
)

cc_library(
    name = "libusb",
    srcs = [
        "libusb/core.c",
        "libusb/descriptor.c",
        "libusb/hotplug.c",
        "libusb/io.c",
        "libusb/strerror.c",
        "libusb/sync.c",
        # POSIX platform
        "libusb/os/events_posix.c",
        "libusb/os/events_posix.h",
        "libusb/os/threads_posix.c",
        "libusb/os/threads_posix.h",
        # Linux OS
        "libusb/os/linux_usbfs.c",
        "libusb/os/linux_usbfs.h",
        "libusb/os/linux_udev.c",
        # Private headers
        "libusb/libusbi.h",
        "libusb/version.h",
        "libusb/version_nano.h",
        ":gen_config_h",
    ],
    hdrs = [
        "libusb/libusb.h",
    ],
    copts = [
        "-fvisibility=hidden",
        "-Wno-error",
        "-fPIC",
    ],
    includes = [
        "libusb",
        ".",
    ],
    deps = [
        "@lowrisc_opentitan//third_party/host_libs:udev",
    ],
)

genrule(
    name = "gen_pc",
    outs = ["libusb-1.0.pc"],
    cmd = """
    cat << 'EOF' > $@
prefix=$${pcfiledir}/../..
exec_prefix=$${prefix}
libdir=$${exec_prefix}/lib
includedir=$${prefix}/include

Name: libusb-1.0
Description: C API for USB device access
Version: 1.0.26
Libs: -L$${libdir} -lusb-1.0
Cflags: -I$${includedir}/libusb-1.0
EOF
    """,
)

genrule(
    name = "libusb_install",
    srcs = [
        ":libusb",
        "libusb/libusb.h",
        ":gen_pc",
    ],
    outs = [
        "install/lib/libusb-1.0.a",
        "install/include/libusb-1.0/libusb.h",
        "install/lib/pkgconfig/libusb-1.0.pc",
    ],
    cmd = """
    mkdir -p $$(dirname $(location install/lib/pkgconfig/libusb-1.0.pc))
    mkdir -p $$(dirname $(location install/include/libusb-1.0/libusb.h))

    found=0
    for f in $(locations :libusb); do
        if [[ $$f == *.a ]]; then
            cp $$f $(location install/lib/libusb-1.0.a)
            found=1
            break
        fi
    done
    if [ $$found -eq 0 ]; then
        echo "Error: libusb.a not found" >&2
        exit 1
    fi

    cp $(location libusb/libusb.h) $(location install/include/libusb-1.0/libusb.h)
    cp $(location :gen_pc) $(location install/lib/pkgconfig/libusb-1.0.pc)
    """,
)

filegroup(
    name = "install_files",
    srcs = [":libusb_install"],
)
